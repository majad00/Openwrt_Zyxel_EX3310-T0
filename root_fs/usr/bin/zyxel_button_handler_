#!/bin/sh
# Written by Majad qureshi as part of wrapper

logger -t BTN_HANDLER "Zyxel Hardware Button Handler Started"

while true; do
    read -r RAW_COUNT < /proc/tc3162/reset_button 2>/dev/null
    COUNT=${RAW_COUNT%% *}
    COUNT=${COUNT:-0}

    if [ "$COUNT" -eq 1 ]; then
        logger -t BTN_HANDLER "Button Event: Pressed"
        BUTTON=reset ACTION=pressed /sbin/hotplug-call button 2>/dev/null
    
    elif [ "$COUNT" -ge 10 ]; then
        logger -t BTN_HANDLER "Button Event: 10 Seconds Reached. Wiping Configuration..."
        BUTTON=reset ACTION=released SEEN=10 /sbin/hotplug-call button 2>/dev/null
        rm -f /overlay/.reset /.reset        
        echo "80 8 1 0 0" > /proc/tc3162/led_def
        echo "33 4 1 0 0" > /proc/tc3162/led_def
        echo "82 6 1 0 1" > /proc/tc3162/led_def
        echo "84 3 1 0 1" > /proc/tc3162/led_def
        echo 1 > /proc/tc3162/led_pwr_green 2>/dev/null
        echo 0 > /proc/tc3162/led_pwr_red 2>/dev/null
        echo 0 > /proc/tc3162/led_internet_red 2>/dev/null
        
        sync
        reboot
        sleep 10 
        exit 0
    fi
    sleep 1
done
